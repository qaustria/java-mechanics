{
    "compilerOptions": {
        "module": "ES2020",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "allowSyntheticDefaultImports": true,
        "target": "ES2020",
        "noImplicitAny": false,
        "removeComments": true,
        "preserveConstEnums": true,
        "sourceMap": false,
        "outDir": "scripts/",
        "strict": false,
        "noImplicitReturns": false,
        "strictNullChecks": false,
        "allowJs": true,
        "resolveJsonModule": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "**/__tests__/*"]
}
